<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <connectionStrings>
        <!-- Replace values below with your DB server, credentials and database name -->
        <add name="InsidashTallyDb" connectionString="" providerName="" />
    </connectionStrings>

    <appSettings>
        <!-- Optional: AI provider keys (fill if using AI services) -->
